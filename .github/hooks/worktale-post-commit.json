{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "description": "Capture commit in Worktale after git commit",
        "toolNames": ["run_in_terminal"],
        "matchPattern": "git commit",
        "command": "bash -c 'worktale capture --silent 2>/dev/null || true'"
      }
    ]
  }
}
